<style>
  .home-field-work {
    background: #0c0d0f;
    color: #fff;
    padding: 96px 32px 0;
  }

  .home-field-work__header {
    max-width: 1280px;
    margin: 0 auto 56px;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 40px;
  }

  .home-field-work__heading-group {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .home-field-work__eyebrow {
    font-size: 11px;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: #eab97f;
    font-weight: 500;
  }

  .home-field-work__heading {
    font-family: Georgia, 'Times New Roman', serif;
    font-size: clamp(36px, 3.6vw, 54px);
    line-height: 1.1;
    letter-spacing: -0.015em;
    color: #fff;
    font-weight: 400;
    margin: 0;
  }

  .home-field-work__link {
    font-size: 12px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #eab97f;
    font-weight: 500;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding-bottom: 4px;
    border-bottom: 1px solid rgba(234, 185, 127, 0.5);
    transition: color 0.3s ease, border-color 0.3s ease;
    white-space: nowrap;
  }

  .home-field-work__link:hover {
    color: #fff;
    border-bottom-color: #fff;
  }

  .home-field-work__link svg {
    transition: transform 0.3s ease;
  }

  .home-field-work__link:hover svg {
    transform: translateX(4px);
  }

  .home-field-work__grid {
    max-width: 1280px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 24px;
  }

  .home-field-work__tile {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: #1a1a1c;
  }

  .home-field-work__tile:first-child {
    aspect-ratio: 4 / 3;
  }

  .home-field-work__tile:last-child {
    aspect-ratio: 3 / 4;
  }

  .home-field-work__tile img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1.2s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .home-field-work__tile:hover img {
    transform: scale(1.04);
  }

  .home-field-work__tile-caption {
    position: absolute;
    left: 20px;
    bottom: 20px;
    font-size: 11px;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: #fff;
    background: rgba(12, 13, 15, 0.7);
    padding: 8px 14px;
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }

  @media (max-width: 899px) {
    .home-field-work {
      padding: 72px 20px 0;
    }
    .home-field-work__header {
      flex-direction: column;
      align-items: flex-start;
      margin-bottom: 36px;
    }
    .home-field-work__grid {
      grid-template-columns: 1fr;
    }
    .home-field-work__tile:first-child,
    .home-field-work__tile:last-child {
      aspect-ratio: 4 / 3;
    }
  }
</style>

<section class="home-field-work">
  <div class="home-field-work__header">
    <div class="home-field-work__heading-group">
      {% if section.settings.eyebrow != blank %}
        <div class="home-field-work__eyebrow">{{ section.settings.eyebrow }}</div>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="home-field-work__heading">{{ section.settings.heading }}</h2>
      {% endif %}
    </div>
    {% if section.settings.link_label != blank and section.settings.link_url != blank %}
      <a href="{{ section.settings.link_url }}" class="home-field-work__link">
        <span>{{ section.settings.link_label }}</span>
        <svg width="18" height="10" viewBox="0 0 18 10" fill="none" aria-hidden="true">
          <path d="M1 5H17M17 5L13 1M17 5L13 9" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
    {% endif %}
  </div>

  <div class="home-field-work__grid">
    {% if section.settings.image_1 != blank %}
      <figure class="home-field-work__tile">
        <img
          src="{{ section.settings.image_1 | image_url: width: 1600 }}"
          srcset="{{ section.settings.image_1 | image_url: width: 800 }} 800w, {{ section.settings.image_1 | image_url: width: 1600 }} 1600w"
          sizes="(max-width: 899px) 92vw, 55vw"
          alt="{{ section.settings.image_1.alt | escape }}"
          loading="lazy"
          width="{{ section.settings.image_1.width }}"
          height="{{ section.settings.image_1.height }}">
        {% if section.settings.caption_1 != blank %}
          <figcaption class="home-field-work__tile-caption">{{ section.settings.caption_1 }}</figcaption>
        {% endif %}
      </figure>
    {% endif %}

    {% if section.settings.image_2 != blank %}
      <figure class="home-field-work__tile">
        <img
          src="{{ section.settings.image_2 | image_url: width: 1200 }}"
          srcset="{{ section.settings.image_2 | image_url: width: 600 }} 600w, {{ section.settings.image_2 | image_url: width: 1200 }} 1200w"
          sizes="(max-width: 899px) 92vw, 40vw"
          alt="{{ section.settings.image_2.alt | escape }}"
          loading="lazy"
          width="{{ section.settings.image_2.width }}"
          height="{{ section.settings.image_2.height }}">
        {% if section.settings.caption_2 != blank %}
          <figcaption class="home-field-work__tile-caption">{{ section.settings.caption_2 }}</figcaption>
        {% endif %}
      </figure>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Home Field Work",
  "tag": "section",
  "class": "section-home-field-work",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Field Work"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Six seasons of frames."
    },
    {
      "type": "text",
      "id": "link_label",
      "label": "Link label",
      "default": "View the gallery"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Link URL"
    },
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Image 1 (larger, left)"
    },
    {
      "type": "text",
      "id": "caption_1",
      "label": "Caption 1"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Image 2 (right)"
    },
    {
      "type": "text",
      "id": "caption_2",
      "label": "Caption 2"
    }
  ],
  "presets": [
    {
      "name": "Home Field Work"
    }
  ]
}
{% endschema %}
