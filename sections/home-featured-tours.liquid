<style>
  .home-featured-tours {
    background: #0c0d0f;
    color: #fff;
    padding: 24px 32px 96px;
  }

  .home-featured-tours__inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .home-featured-tours__stack {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .home-featured-tours__card {
    position: relative;
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 0;
    background: rgba(255, 255, 255, 0.025);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 4px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.5s ease, background 0.5s ease, transform 0.5s ease;
    isolation: isolate;
  }

  .home-featured-tours__card::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, #eab97f 50%, transparent 100%);
    opacity: 0;
    transition: opacity 0.5s ease;
    z-index: 2;
  }

  .home-featured-tours__card:hover {
    border-color: rgba(234, 185, 127, 0.4);
    background: rgba(255, 255, 255, 0.04);
    transform: translateY(-2px);
  }

  .home-featured-tours__card:hover::before {
    opacity: 1;
  }

  .home-featured-tours__media {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: #1a1a1c;
  }

  .home-featured-tours__media img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1.2s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .home-featured-tours__card:hover .home-featured-tours__media img {
    transform: scale(1.05);
  }

  .home-featured-tours__media::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, rgba(12, 13, 15, 0) 70%, rgba(12, 13, 15, 0.6) 100%);
    pointer-events: none;
  }

  .home-featured-tours__season {
    position: absolute;
    top: 18px;
    left: 18px;
    z-index: 1;
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #eab97f;
    background: rgba(12, 13, 15, 0.7);
    padding: 6px 12px;
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    border: 1px solid rgba(234, 185, 127, 0.25);
  }

  .home-featured-tours__body {
    padding: 36px 40px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 24px;
    min-height: 100%;
  }

  .home-featured-tours__dates {
    font-size: 12px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #eab97f;
    font-weight: 500;
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }

  .home-featured-tours__dates::before {
    content: "";
    display: inline-block;
    width: 24px;
    height: 1px;
    background: #eab97f;
    opacity: 0.6;
  }

  .home-featured-tours__title {
    font-family: Georgia, 'Times New Roman', serif;
    font-size: clamp(24px, 2.4vw, 34px);
    line-height: 1.1;
    letter-spacing: -0.012em;
    color: #fff;
    font-weight: 400;
    margin: 14px 0 12px;
    text-wrap: balance;
  }

  .home-featured-tours__blurb {
    font-size: 14px;
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.7);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .home-featured-tours__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    padding-top: 20px;
    border-top: 1px solid rgba(255, 255, 255, 0.07);
  }

  .home-featured-tours__meta {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .home-featured-tours__meta-label {
    font-size: 10px;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.5);
    font-weight: 500;
  }

  .home-featured-tours__meta-value {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.9);
    font-weight: 500;
    letter-spacing: 0.01em;
  }

  .home-featured-tours__meta-row {
    display: flex;
    align-items: center;
    gap: 28px;
  }

  .home-featured-tours__cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 11px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #eab97f;
    font-weight: 500;
    white-space: nowrap;
  }

  .home-featured-tours__cta svg {
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .home-featured-tours__card:hover .home-featured-tours__cta svg {
    transform: translateX(6px);
  }

  .home-featured-tours__viewall {
    display: flex;
    justify-content: center;
    margin-top: 56px;
  }

  .home-featured-tours__viewall-link {
    font-size: 12px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #eab97f;
    font-weight: 500;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 14px 28px;
    border: 1px solid rgba(234, 185, 127, 0.5);
    border-radius: 2px;
    transition: color 0.3s ease, border-color 0.3s ease, background 0.3s ease;
  }

  .home-featured-tours__viewall-link:hover {
    color: #0c0d0f;
    background: #eab97f;
    border-color: #eab97f;
  }

  .home-featured-tours__viewall-link svg {
    transition: transform 0.3s ease;
  }

  .home-featured-tours__viewall-link:hover svg {
    transform: translateX(4px);
  }

  .home-featured-tours__empty {
    padding: 48px;
    text-align: center;
    color: rgba(255, 255, 255, 0.5);
    border: 1px dashed rgba(255, 255, 255, 0.15);
    border-radius: 4px;
  }

  @media (max-width: 899px) {
    .home-featured-tours {
      padding: 16px 20px 72px;
    }
    .home-featured-tours__card {
      grid-template-columns: 1fr;
    }
    .home-featured-tours__body {
      padding: 28px 24px;
    }
    .home-featured-tours__footer {
      flex-direction: column;
      align-items: flex-start;
      gap: 16px;
    }
    .home-featured-tours__meta-row {
      gap: 20px;
    }
  }
</style>

{%- liquid
  assign source = section.settings.collection
  assign product_count = section.settings.product_count | default: 4
  assign products = source.products | slice: 0, product_count
-%}

<section class="home-featured-tours">
  <div class="home-featured-tours__inner">
    {% if products.size > 0 %}
      <div class="home-featured-tours__stack">
        {% for product in products %}
          {%- liquid
            assign start_raw = product.metafields.tour_info.start_date | strip
            assign end_raw = product.metafields.tour_info.end_date | strip
            assign pre_start = start_raw | date: '%s'
            assign pre_end = end_raw | date: '%s'
            assign season_year = start_raw | date: '%Y'
            assign departure_city = product.metafields.tour_info.departure_city | default: 'Denver, CO'
            assign hero_blurb = product.metafields.tour_info.hero_blurb
            assign money_price = product.metafields.my_fields.total_price.value | money | remove: '.00'
            assign card_image = product.featured_image | default: product.images[0]

            assign date_range = 'Dates TBA'
            if start_raw != blank and end_raw != blank
              assign start_month = pre_start | date: '%b'
              assign end_month = pre_end | date: '%b'
              assign start_day = pre_start | date: '%-d'
              assign end_day = pre_end | date: '%-d'
              assign end_year = pre_end | date: '%Y'
              if start_month == end_month
                capture date_range
                  echo start_month
                  echo ' '
                  echo start_day
                  echo ' – '
                  echo end_day
                  echo ', '
                  echo end_year
                endcapture
              else
                capture date_range
                  echo start_month
                  echo ' '
                  echo start_day
                  echo ' – '
                  echo end_month
                  echo ' '
                  echo end_day
                  echo ', '
                  echo end_year
                endcapture
              endif
            endif
          -%}

          <a href="{{ product.url }}" class="home-featured-tours__card">
            <div class="home-featured-tours__media">
              {% if season_year != blank %}
                <span class="home-featured-tours__season">{{ season_year }} Season</span>
              {% endif %}
              {% if card_image != blank %}
                <img
                  src="{{ card_image | image_url: width: 1200 }}"
                  srcset="{{ card_image | image_url: width: 600 }} 600w, {{ card_image | image_url: width: 1200 }} 1200w, {{ card_image | image_url: width: 1800 }} 1800w"
                  sizes="(max-width: 899px) 92vw, 620px"
                  alt="{{ card_image.alt | default: product.title | escape }}"
                  loading="lazy"
                  width="{{ card_image.width }}"
                  height="{{ card_image.height }}">
              {% endif %}
            </div>

            <div class="home-featured-tours__body">
              <div>
                <div class="home-featured-tours__dates">{{ date_range }}</div>
                <h3 class="home-featured-tours__title">{{ product.title }}</h3>
                {% if hero_blurb != blank %}
                  <p class="home-featured-tours__blurb">{{ hero_blurb }}</p>
                {% endif %}
              </div>

              <div class="home-featured-tours__footer">
                <div class="home-featured-tours__meta-row">
                  <div class="home-featured-tours__meta">
                    <span class="home-featured-tours__meta-label">Departs</span>
                    <span class="home-featured-tours__meta-value">{{ departure_city }}</span>
                  </div>
                  <div class="home-featured-tours__meta">
                    <span class="home-featured-tours__meta-label">Tuition</span>
                    <span class="home-featured-tours__meta-value">
                      {% if money_price != blank %}{{ money_price }}{% else %}{{ product.price | money }}{% endif %}
                    </span>
                  </div>
                </div>

                <span class="home-featured-tours__cta">
                  <span>{{ section.settings.card_cta_label | default: 'View tour' }}</span>
                  <svg width="18" height="10" viewBox="0 0 18 10" fill="none" aria-hidden="true">
                    <path d="M1 5H17M17 5L13 1M17 5L13 9" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </span>
              </div>
            </div>
          </a>
        {% endfor %}
      </div>

      {% if section.settings.link_label != blank and section.settings.link_url != blank %}
        <div class="home-featured-tours__viewall">
          <a href="{{ section.settings.link_url }}" class="home-featured-tours__viewall-link">
            <span>{{ section.settings.link_label }}</span>
            <svg width="18" height="10" viewBox="0 0 18 10" fill="none" aria-hidden="true">
              <path d="M1 5H17M17 5L13 1M17 5L13 9" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </a>
        </div>
      {% endif %}
    {% else %}
      <div class="home-featured-tours__empty">Select a collection in the theme editor to show tours here.</div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Home Featured Tours",
  "tag": "section",
  "class": "section-home-featured-tours",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "product_count",
      "label": "Number of tours to show",
      "min": 1,
      "max": 8,
      "step": 1,
      "default": 4
    },
    {
      "type": "text",
      "id": "card_cta_label",
      "label": "Card CTA label",
      "default": "View tour"
    },
    {
      "type": "header",
      "content": "View all link"
    },
    {
      "type": "text",
      "id": "link_label",
      "label": "Link label",
      "default": "View all trips"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Link URL"
    }
  ],
  "presets": [
    {
      "name": "Home Featured Tours",
      "settings": {
        "product_count": 4
      }
    }
  ]
}
{% endschema %}
