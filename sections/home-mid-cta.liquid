{{ 'pdp-tour.css' | asset_url | stylesheet_tag }}

{% assign bg_url = section.settings.background_image | image_url: width: 2400 | default: 'https://cdn.shopify.com/s/files/1/0590/7863/9796/files/m4.webp?v=1776654991&width=2048' %}

<section class="tour-pdp home-mid-cta">
  <div class="tour-pdp-mid-cta" style="background-image: url('{{ bg_url }}');">
    <div class="tour-pdp-mid-cta__inner tour-reveal">
      {% if section.settings.eyebrow != blank %}
        <span class="tour-pdp-mid-cta__date">
          <span class="tour-pdp-mid-cta__date-rule" aria-hidden="true"></span>
          <span class="tour-pdp-mid-cta__date-text">{{ section.settings.eyebrow }}</span>
          <span class="tour-pdp-mid-cta__date-rule" aria-hidden="true"></span>
        </span>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 class="tour-pdp-mid-cta__heading">{{ section.settings.heading }}</h2>
      {% endif %}

      <div class="tour-pdp-mid-cta__ornament" aria-hidden="true">
        <span class="tour-pdp-mid-cta__ornament-rule"></span>
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
          <path d="M7 0L8 6L14 7L8 8L7 14L6 8L0 7L6 6L7 0Z" fill="currentColor" />
        </svg>
        <span class="tour-pdp-mid-cta__ornament-rule"></span>
      </div>

      {% if section.settings.copy != blank %}
        <p class="tour-pdp-mid-cta__copy">{{ section.settings.copy }}</p>
      {% endif %}

      <ul class="tour-pdp-mid-cta__pillars">
        <li class="tour-pdp-mid-cta__pillar">
          <span class="tour-pdp-mid-cta__pillar-icon" aria-hidden="true">
            <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="9" />
              <circle cx="12" cy="12" r="4.5" />
              <circle cx="12" cy="12" r="1.2" fill="currentColor" stroke="none" />
              <path d="M12 1.5v3" />
              <path d="M12 19.5v3" />
              <path d="M1.5 12h3" />
              <path d="M19.5 12h3" />
            </svg>
          </span>
          <div class="tour-pdp-mid-cta__pillar-body">
            <span class="tour-pdp-mid-cta__pillar-title">{{ section.settings.pillar_1_title }}</span>
            <span class="tour-pdp-mid-cta__pillar-sub">{{ section.settings.pillar_1_sub }}</span>
          </div>
        </li>

        <li class="tour-pdp-mid-cta__pillar">
          <span class="tour-pdp-mid-cta__pillar-icon" aria-hidden="true">
            <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round">
              <path d="M17.5 16.5a5 5 0 0 0-1.3-9.83A6.5 6.5 0 0 0 4 9.5" />
              <path d="M5 16h9" />
              <path d="M12.5 13l-2.5 4.5h3l-1.5 3.5" />
            </svg>
          </span>
          <div class="tour-pdp-mid-cta__pillar-body">
            <span class="tour-pdp-mid-cta__pillar-title">{{ section.settings.pillar_2_title }}</span>
            <span class="tour-pdp-mid-cta__pillar-sub">{{ section.settings.pillar_2_sub }}</span>
          </div>
        </li>

        <li class="tour-pdp-mid-cta__pillar">
          <span class="tour-pdp-mid-cta__pillar-icon" aria-hidden="true">
            <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="8" r="3.8" />
              <path d="M4.5 20.5c0-4 3.5-6.5 7.5-6.5s7.5 2.5 7.5 6.5" />
            </svg>
          </span>
          <div class="tour-pdp-mid-cta__pillar-body">
            <span class="tour-pdp-mid-cta__pillar-title">{{ section.settings.pillar_3_title }}</span>
            <span class="tour-pdp-mid-cta__pillar-sub">{{ section.settings.pillar_3_sub }}</span>
          </div>
        </li>
      </ul>

      <a href="{{ section.settings.button_link | default: '/collections/tours' }}" class="tour-pdp-cta-btn tour-pdp-mid-cta__btn">
        <span>{{ section.settings.button_label | default: 'View All Trips' }}</span>
        <svg width="18" height="10" viewBox="0 0 18 10" fill="none" aria-hidden="true">
          <path d="M1 5H17M17 5L13 1M17 5L13 9" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Home Mid CTA",
  "tag": "section",
  "class": "section-home-mid-cta",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "2026 & 2027 Storm Seasons"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Tours for photographers who want more than luck."
    },
    {
      "type": "textarea",
      "id": "copy",
      "label": "Body copy",
      "default": "We handle the positioning, timing, and coaching so you can focus on making photographs when the light and weather finally align."
    },
    {
      "type": "header",
      "content": "Pillar 1"
    },
    {
      "type": "text",
      "id": "pillar_1_title",
      "label": "Title",
      "default": "Forecast-driven positioning"
    },
    {
      "type": "text",
      "id": "pillar_1_sub",
      "label": "Subtitle",
      "default": "Not guesswork."
    },
    {
      "type": "header",
      "content": "Pillar 2"
    },
    {
      "type": "text",
      "id": "pillar_2_title",
      "label": "Title",
      "default": "Real-time adjustments"
    },
    {
      "type": "text",
      "id": "pillar_2_sub",
      "label": "Subtitle",
      "default": "Adapt. Pivot. Capture."
    },
    {
      "type": "header",
      "content": "Pillar 3"
    },
    {
      "type": "text",
      "id": "pillar_3_title",
      "label": "Title",
      "default": "Expert coaching in the field"
    },
    {
      "type": "text",
      "id": "pillar_3_sub",
      "label": "Subtitle",
      "default": "When it matters most."
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "View All Trips"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Home Mid CTA"
    }
  ]
}
{% endschema %}
