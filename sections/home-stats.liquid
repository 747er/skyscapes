<style>
  .home-stats {
    background: #0c0d0f;
    color: #fff;
    padding: 96px 24px;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .home-stats__inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    align-items: stretch;
  }

  .home-stats__item {
    position: relative;
    padding: 8px 40px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    text-align: left;
  }

  .home-stats__item + .home-stats__item::before {
    content: "";
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 1px;
    height: 64px;
    background: rgba(255, 255, 255, 0.14);
  }

  .home-stats__index {
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: rgba(234, 185, 127, 0.8);
    font-weight: 500;
  }

  .home-stats__value {
    font-family: Georgia, 'Times New Roman', serif;
    font-size: clamp(28px, 2.6vw, 38px);
    line-height: 1.05;
    color: #fff;
    font-weight: 400;
    letter-spacing: -0.01em;
  }

  .home-stats__value em {
    color: #eab97f;
    font-style: normal;
  }

  .home-stats__label {
    font-size: 11px;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.55);
    font-weight: 500;
    line-height: 1.4;
  }

  @media (max-width: 899px) {
    .home-stats {
      padding: 64px 20px;
    }
    .home-stats__inner {
      grid-template-columns: repeat(2, 1fr);
      row-gap: 48px;
    }
    .home-stats__item {
      padding: 0 20px;
    }
    .home-stats__item + .home-stats__item::before {
      display: none;
    }
    .home-stats__item:nth-child(2n)::before {
      content: "";
      position: absolute;
      left: 0;
      top: 50%;
      transform: translateY(-50%);
      width: 1px;
      height: 64px;
      background: rgba(255, 255, 255, 0.14);
      display: block;
    }
  }
</style>

<section class="home-stats">
  <div class="home-stats__inner">
    {% for block in section.blocks %}
      <div class="home-stats__item" {{ block.shopify_attributes }}>
        <div class="home-stats__index">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</div>
        <div class="home-stats__value">{{ block.settings.value }}</div>
        <div class="home-stats__label">{{ block.settings.label }}</div>
      </div>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Home Stats Band",
  "tag": "section",
  "class": "section-home-stats",
  "max_blocks": 4,
  "settings": [],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        {
          "type": "text",
          "id": "value",
          "label": "Value",
          "info": "Wrap a word or number in <em></em> to color it gold.",
          "default": "<em>6</em> Seasons"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "In the field"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Home Stats Band",
      "blocks": [
        {
          "type": "stat",
          "settings": { "value": "<em>6</em> Seasons", "label": "In the field" }
        },
        {
          "type": "stat",
          "settings": { "value": "Forecaster-led", "label": "Every departure" }
        },
        {
          "type": "stat",
          "settings": { "value": "<em>6</em> Photographers", "label": "Per tour" }
        },
        {
          "type": "stat",
          "settings": { "value": "Great Plains", "label": "Region" }
        }
      ]
    }
  ]
}
{% endschema %}
