<style>
  .home-stats {
    background: #0c0d0f;
    color: #fff;
    padding: 96px 32px;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .home-stats__inner {
    max-width: 1080px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    align-items: stretch;
  }

  .home-stats__item {
    position: relative;
    padding: 8px 32px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 18px;
    text-align: center;
  }

  .home-stats__item + .home-stats__item::before {
    content: "";
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 1px;
    height: 104px;
    background: rgba(255, 255, 255, 0.18);
  }

  .home-stats__value {
    font-family: Georgia, 'Times New Roman', serif;
    font-size: clamp(56px, 6vw, 88px);
    line-height: 1;
    color: #eab97f;
    font-weight: 400;
    letter-spacing: -0.02em;
  }

  .home-stats__rule {
    width: 24px;
    height: 1px;
    background: rgba(255, 255, 255, 0.35);
  }

  .home-stats__label {
    font-size: 12px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.85);
    font-weight: 500;
    line-height: 1.5;
    max-width: 20ch;
  }

  @media (max-width: 749px) {
    .home-stats {
      padding: 64px 20px;
    }
    .home-stats__inner {
      grid-template-columns: 1fr;
      row-gap: 56px;
    }
    .home-stats__item {
      padding: 0 20px;
    }
    .home-stats__item + .home-stats__item::before {
      left: 50%;
      top: -28px;
      transform: translateX(-50%);
      width: 48px;
      height: 1px;
    }
  }
</style>

<section class="home-stats">
  <div class="home-stats__inner">
    {% for block in section.blocks %}
      <div class="home-stats__item" {{ block.shopify_attributes }}>
        <div class="home-stats__value">{{ block.settings.value }}</div>
        <div class="home-stats__rule" aria-hidden="true"></div>
        <div class="home-stats__label">{{ block.settings.label }}</div>
      </div>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Home Stats Band",
  "tag": "section",
  "class": "section-home-stats",
  "max_blocks": 3,
  "settings": [],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        {
          "type": "text",
          "id": "value",
          "label": "Value",
          "info": "Keep to a single number or short figure for best results.",
          "default": "6"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Seasons in the field"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Home Stats Band",
      "blocks": [
        {
          "type": "stat",
          "settings": { "value": "6", "label": "Seasons in the field" }
        },
        {
          "type": "stat",
          "settings": { "value": "7", "label": "Days per departure" }
        },
        {
          "type": "stat",
          "settings": { "value": "6", "label": "Photographers per tour" }
        }
      ]
    }
  ]
}
{% endschema %}
