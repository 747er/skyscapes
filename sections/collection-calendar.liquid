{{ 'calendar.css' | asset_url | stylesheet_tag }}

<div class="shopify-section" id="calendar-section">
  <div id="experiences" class="page-width">
    <div class="tour-list">
      {%- for product in collection.products -%}
        {% capture coming_start %}{{product.metafields.tour_info.start_date}}{% endcapture %}
        {% capture coming_end %}{{product.metafields.tour_info.end_date}}{% endcapture %}
        {% assign today_date = 'now' | date: '%s' %}
        {% assign pre_start = coming_start | date: '%s' %}
        {% assign pre_end = coming_end | date: '%s' %}

        <a href="{{ product.url }}" class="tour-card{% unless product.available %} tour-card--sold-out{% endunless %}" id="tour-{{ forloop.index | plus: 1 }}">

          <span class="tour-card__index" aria-hidden="true">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>

          <div class="tour-card__image">
            <img
              src="{{ product.featured_image.src | img_url: '900x' }}"
              alt="{{ product.title }}"
              loading="lazy">
          </div>

          <div class="tour-card__content">

            <div class="tour-card__status">
              {% if product.available %}
                <span class="tour-card__status-dot tour-card__status-dot--open"></span>
                <span class="tour-card__status-text tour-card__status-text--open">Spots Available</span>
              {% else %}
                <span class="tour-card__status-dot tour-card__status-dot--full"></span>
                <span class="tour-card__status-text tour-card__status-text--full">Sold Out</span>
              {% endif %}
            </div>

            <h2 class="tour-card__title">{{ product.title }}</h2>

            <div class="tour-card__divider"></div>

            <div class="tour-card__meta">
              <div class="tour-card__detail">
                <span class="tour-card__label">Dates</span>
                <span class="tour-card__value">{{ pre_start | date: "%b %d" }} &ndash; {{ pre_end | date: "%b %d, %Y" }}</span>
              </div>
              <div class="tour-card__detail">
                <span class="tour-card__label">Deposit</span>
                <span class="tour-card__value tour-card__value--price">{{ product.price | money }}</span>
              </div>
            </div>

            {% if product.metafields.custom.guides2 != blank %}
              <div class="tour-card__guides">
                <span class="tour-card__label">Your Guides</span>
                <div class="tour-card__guide-list">
                  {% for guide in product.metafields.custom.guides2.value %}
                    {% assign guide_pic = guide.photo %}
                    <div class="tour-card__guide">
                      <div class="tour-card__guide-photo {{ guide.slug }}" style="background-image: url('{{ guide_pic }}');"></div>
                      <span class="tour-card__guide-name">{{ guide.name }}</span>
                    </div>
                  {% endfor %}
                </div>
              </div>
            {% else %}
              <div class="tour-card__guides">
                <span class="tour-card__label">Guides</span>
                <span class="tour-card__value tour-card__value--muted">To be announced</span>
              </div>
            {% endif %}

            <div class="tour-card__cta">
              <span class="tour-card__cta-btn">
                {% if product.available %}Reserve Your Spot{% else %}View Details{% endif %}
                <svg width="18" height="18" viewBox="0 0 20 20" fill="none">
                  <path d="M4 10h12M12 6l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </div>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
  {
    "name": "Collection Calendar",
    "tag": "section",
    "class": "spaced-section spaced-section--full-width",
    "settings": [
      {
        "type": "image_picker",
        "id": "image",
        "label": "t:sections.image-banner.settings.image.label"
      }, {
        "type": "image_picker",
        "id": "image_map",
        "label": "t:sections.image-banner.settings.image_map.label"
      }
    ],
    "presets": [
      {
        "name": "Collection Calendar"
      }
    ]
  }
{% endschema %}
