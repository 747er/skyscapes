<style>
  .home-section-heading {
    background: #0c0d0f;
    color: #fff;
    padding: 96px 32px 24px;
  }

  .home-section-heading__inner {
    max-width: 1280px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .home-section-heading--center .home-section-heading__inner {
    align-items: center;
    text-align: center;
  }

  .home-section-heading__eyebrow {
    font-size: 11px;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: #eab97f;
    font-weight: 500;
  }

  .home-section-heading__heading {
    font-family: Georgia, 'Times New Roman', serif;
    font-size: clamp(36px, 3.8vw, 56px);
    line-height: 1.1;
    letter-spacing: -0.015em;
    color: #fff;
    font-weight: 400;
    margin: 0;
    text-wrap: balance;
  }

  .home-section-heading__sub {
    font-size: 14px;
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.65);
    max-width: 56ch;
    margin: 8px 0 0;
  }

  @media (max-width: 749px) {
    .home-section-heading {
      padding: 64px 20px 16px;
    }
  }
</style>

<section class="home-section-heading {% if section.settings.alignment == 'center' %}home-section-heading--center{% endif %}">
  <div class="home-section-heading__inner">
    {% if section.settings.eyebrow != blank %}
      <div class="home-section-heading__eyebrow">{{ section.settings.eyebrow }}</div>
    {% endif %}
    {% if section.settings.heading != blank %}
      <h2 class="home-section-heading__heading">{{ section.settings.heading }}</h2>
    {% endif %}
    {% if section.settings.sub != blank %}
      <p class="home-section-heading__sub">{{ section.settings.sub }}</p>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Home Section Heading",
  "tag": "section",
  "class": "section-home-section-heading",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Booking Now"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "2026 & 2027 Departures"
    },
    {
      "type": "textarea",
      "id": "sub",
      "label": "Subheading (optional)"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "left"
    }
  ],
  "presets": [
    {
      "name": "Home Section Heading"
    }
  ]
}
{% endschema %}
