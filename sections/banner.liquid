{{ 'calendar.css' | asset_url | stylesheet_tag }}

{%- comment -%} HERO {%- endcomment -%}
<div class="tours-hero" id="tours-hero">
  <div class="tours-hero__light" id="hero-light"></div>
  <div class="tours-hero__light tours-hero__light--secondary" id="hero-light-2"></div>
  <div class="tours-hero__light tours-hero__light--trail" id="hero-light-trail"></div>
  <div class="tours-hero__grain"></div>
  <div class="tours-hero__haze"></div>

  <div class="tours-hero__inner page-width">
    <span class="tours-hero__eyebrow">{{ section.settings.subheading }}</span>
    <h1 class="tours-hero__title">{{ section.settings.title }}</h1>
    <div class="tours-hero__rule"></div>
    <p class="tours-hero__subtitle poppins-extralight">{{ section.settings.description }}</p>
  </div>
</div>

{%- comment -%} ORIENTATION BAND {%- endcomment -%}
<div class="tours-band">
  <div class="tours-band__inner page-width">
    {% if section.settings.feature_1 != blank %}
      <div class="tours-band__item">
        <svg class="tours-band__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/>
        </svg>
        <span>{{ section.settings.feature_1 }}</span>
      </div>
    {% endif %}
    {% if section.settings.feature_2 != blank %}
      <div class="tours-band__item">
        <svg class="tours-band__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
        </svg>
        <span>{{ section.settings.feature_2 }}</span>
      </div>
    {% endif %}
    {% if section.settings.feature_3 != blank %}
      <div class="tours-band__item">
        <svg class="tours-band__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/>
        </svg>
        <span>{{ section.settings.feature_3 }}</span>
      </div>
    {% endif %}
    {% if section.settings.feature_4 != blank %}
      <div class="tours-band__item">
        <svg class="tours-band__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
        </svg>
        <span>{{ section.settings.feature_4 }}</span>
      </div>
    {% endif %}
  </div>
</div>

<script>
(function() {
  var hero = document.getElementById('tours-hero');
  var light = document.getElementById('hero-light');
  var light2 = document.getElementById('hero-light-2');
  var trail = document.getElementById('hero-light-trail');
  if (!hero || !light) return;

  var w = hero.offsetWidth, h = hero.offsetHeight;
  var mx = w * 0.5, my = h * 0.5;
  var cx = w * 0.5, cy = h * 0.5;
  var c2x = w * 0.3, c2y = h * 0.6;
  var tx = w * 0.5, ty = h * 0.5; /* trail — even slower */

  function lerp(a, b, t) { return a + (b - a) * t; }

  function tick() {
    cx = lerp(cx, mx, 0.05);
    cy = lerp(cy, my, 0.05);
    light.style.transform = 'translate(' + cx + 'px, ' + cy + 'px)';

    c2x = lerp(c2x, mx, 0.012);
    c2y = lerp(c2y, my, 0.015);
    light2.style.transform = 'translate(' + c2x + 'px, ' + c2y + 'px)';

    /* Trail — very slow, leaves a fading wake */
    tx = lerp(tx, cx, 0.008);
    ty = lerp(ty, cy, 0.01);
    trail.style.transform = 'translate(' + tx + 'px, ' + ty + 'px)';

    requestAnimationFrame(tick);
  }

  hero.classList.add('tours-hero--active');

  hero.addEventListener('mousemove', function(e) {
    var rect = hero.getBoundingClientRect();
    mx = e.clientX - rect.left;
    my = e.clientY - rect.top;
  });

  hero.addEventListener('mouseleave', function(e) {
    var rect = hero.getBoundingClientRect();
    mx = Math.max(w * 0.15, Math.min(w * 0.85, e.clientX - rect.left));
    my = Math.max(h * 0.2, Math.min(h * 0.8, e.clientY - rect.top));
  });

  window.addEventListener('resize', function() {
    w = hero.offsetWidth;
    h = hero.offsetHeight;
  });

  if ('ontouchstart' in window || navigator.maxTouchPoints > 0) {
    var t = 0;
    setInterval(function() {
      t += 0.003;
      mx = (w * 0.5) + Math.sin(t) * (w * 0.25);
      my = (h * 0.5) + Math.cos(t * 0.7) * (h * 0.15);
    }, 30);
  }

  requestAnimationFrame(tick);
})();
</script>

{% schema %}
  {
    "name": "Tours Hero",
    "settings": [
      {
        "type": "header",
        "content": "Hero"
      },
      {
        "type": "text",
        "id": "subheading",
        "label": "Eyebrow text",
        "default": "Now Booking 2026 & 2027"
      },
      {
        "type": "text",
        "id": "title",
        "label": "Headline",
        "default": "Chase the Light"
      },
      {
        "type": "textarea",
        "id": "description",
        "label": "Subheadline",
        "default": "Multi-day guided photo expeditions into the most dramatic skies on the Great Plains."
      },
      {
        "type": "header",
        "content": "Feature band"
      },
      {
        "type": "text",
        "id": "feature_1",
        "label": "Feature 1",
        "default": "Led by Expert Meteorologists"
      },
      {
        "type": "text",
        "id": "feature_2",
        "label": "Feature 2",
        "default": "Small Group Expeditions"
      },
      {
        "type": "text",
        "id": "feature_3",
        "label": "Feature 3",
        "default": "World-Renowned Photographers"
      },
      {
        "type": "text",
        "id": "feature_4",
        "label": "Feature 4",
        "default": "5 Seasons Strong"
      },
      {
        "type": "image_picker",
        "id": "background_image",
        "label": "Background Image"
      }
    ],
    "presets": [
      {
        "name": "Tours Hero"
      }
    ]
  }
{% endschema %}
