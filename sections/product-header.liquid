{{ 'pdp-tour.css' | asset_url | stylesheet_tag }}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,500;9..144,600;9..144,700;9..144,900&family=JetBrains+Mono:wght@300;400;500&family=Inter+Tight:wght@300;400;500;600&display=swap" rel="stylesheet">

{% assign split_title = product.title | split: ':' %}
{% assign hero_heading = split_title[0] | strip %}
{% assign hero_subtitle = split_title[1] | strip %}
{% capture coming_start %}{{ product.metafields.tour_info.start_date }}{% endcapture %}
{% capture coming_end %}{{ product.metafields.tour_info.end_date }}{% endcapture %}
{% assign coming_start = coming_start | strip %}
{% assign coming_end = coming_end | strip %}
{% assign pre_start = coming_start | date: '%s' %}
{% assign pre_end = coming_end | date: '%s' %}
{% assign season_year = coming_start | date: '%Y' %}
{% assign hero_image = product.featured_image | default: product.images[0] %}
{% assign max_guests = product.metafields.custom.max_guests | default: 6 %}

{%- assign money_price = product.metafields.my_fields.total_price.value | money | remove: '.00' -%}

{% assign spots_remaining = 0 %}
{% assign show_scarcity = false %}
{% if product.available %}
  {% for variant in product.variants %}
    {% if variant.inventory_management != blank and variant.inventory_quantity > 0 %}
      {% assign spots_remaining = spots_remaining | plus: variant.inventory_quantity %}
    {% endif %}
  {% endfor %}
  {% if spots_remaining > 0 and spots_remaining <= 6 %}
    {% assign show_scarcity = true %}
  {% endif %}
{% endif %}

<div class="tour-pdp-grain-global" aria-hidden="true"></div>

<section class="tour-pdp tour-pdp-hero">
  <div
    class="tour-pdp-hero__media"
    style="background-image: url('{{ hero_image | image_url: width: 2400 }}');"
  ></div>
  <div class="tour-pdp-hero__overlay"></div>
  <div class="tour-pdp-hero__grain"></div>

  <div class="tour-pdp-hero__meta-top">
    <span>
      <span class="tour-pdp-hero__meta-dot"></span>
      {% if season_year != blank %}Season {{ season_year }}{% else %}Storm Season{% endif %}
      {% if product.available %}— Now Booking{% endif %}
    </span>
    <span>Great Plains, USA</span>
  </div>

  <div class="tour-pdp-hero__content">
    <h1 class="tour-pdp-hero__headline">
      <span class="tour-pdp-hero__headline-small">A Storm Photography Expedition</span>
      {% if hero_heading != blank %}
        {{ hero_heading | escape }}
      {% else %}
        {{ product.title | escape }}
      {% endif %}
    </h1>

    <div class="tour-pdp-hero__side">
      <div class="tour-pdp-hero__quick-stats">
        <div>
          <span class="tour-pdp-hero__stat-label">Departs</span>
          <span class="tour-pdp-hero__stat-value">
            {% if coming_start != blank %}{{ pre_start | date: '%b %-d' }}{% else %}TBA{% endif %}
          </span>
        </div>
        <div>
          <span class="tour-pdp-hero__stat-label">Returns</span>
          <span class="tour-pdp-hero__stat-value">
            {% if coming_end != blank %}{{ pre_end | date: '%b %-d' }}{% else %}TBA{% endif %}
          </span>
        </div>
        <div>
          <span class="tour-pdp-hero__stat-label">Group</span>
          <span class="tour-pdp-hero__stat-value">{{ max_guests }} max</span>
        </div>
        <div>
          <span class="tour-pdp-hero__stat-label">From</span>
          <span class="tour-pdp-hero__stat-value">
            {% if money_price != blank %}{{ money_price }}{% else %}{{ product.price | money }}{% endif %}
          </span>
        </div>
      </div>
    </div>
  </div>

  <div class="tour-pdp-scroll-cue">Scroll</div>
</section>

{%- comment -%} ── Marquee ── {%- endcomment -%}
<div class="tour-pdp-marquee">
  <div class="tour-pdp-marquee__track">
    <span>Supercells <span class="tour-pdp-marquee__star">✦</span> Mesocyclones <span class="tour-pdp-marquee__star">✦</span> Mammatus <span class="tour-pdp-marquee__star">✦</span> Wall Clouds <span class="tour-pdp-marquee__star">✦</span> Shelf Lines <span class="tour-pdp-marquee__star">✦</span> Lightning <span class="tour-pdp-marquee__star">✦</span> Plains Sunsets <span class="tour-pdp-marquee__star">✦</span></span>
    <span>Supercells <span class="tour-pdp-marquee__star">✦</span> Mesocyclones <span class="tour-pdp-marquee__star">✦</span> Mammatus <span class="tour-pdp-marquee__star">✦</span> Wall Clouds <span class="tour-pdp-marquee__star">✦</span> Shelf Lines <span class="tour-pdp-marquee__star">✦</span> Lightning <span class="tour-pdp-marquee__star">✦</span> Plains Sunsets <span class="tour-pdp-marquee__star">✦</span></span>
  </div>
</div>

{% schema %}
{
  "name": "Product Header",
  "class": "cal",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "default": "Product Header",
      "label": "t:sections.product-header.settings.title.label"
    }
  ],
  "presets": [
    {
      "name": "Product Header"
    }
  ]
}
{% endschema %}
