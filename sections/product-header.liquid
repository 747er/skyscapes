{{ 'pdp-tour.css' | asset_url | stylesheet_tag }}

{% assign split_title = product.title | split: ':' %}
{% assign hero_heading = split_title[0] | strip %}
{% assign hero_subtitle = split_title[1] | strip %}
{% capture coming_start %}{{ product.metafields.tour_info.start_date }}{% endcapture %}
{% capture coming_end %}{{ product.metafields.tour_info.end_date }}{% endcapture %}
{% assign coming_start = coming_start | strip %}
{% assign coming_end = coming_end | strip %}
{% assign pre_start = coming_start | date: '%s' %}
{% assign pre_end = coming_end | date: '%s' %}
{% assign season_year = coming_start | date: '%Y' %}
{% assign hero_image = product.featured_image | default: product.images[0] %}

{% assign spots_remaining = 0 %}
{% assign show_scarcity = false %}
{% if product.available %}
  {% for variant in product.variants %}
    {% if variant.inventory_management != blank and variant.inventory_quantity > 0 %}
      {% assign spots_remaining = spots_remaining | plus: variant.inventory_quantity %}
    {% endif %}
  {% endfor %}
  {% if spots_remaining > 0 and spots_remaining <= 6 %}
    {% assign show_scarcity = true %}
  {% endif %}
{% endif %}

<section class="tour-pdp tour-pdp-hero">
  <div
    class="tour-pdp-hero__media"
    style="background-image: url('{{ hero_image | image_url: width: 2200 }}');"
  ></div>
  <div class="tour-pdp-hero__overlay"></div>
  <div class="tour-pdp-hero__grain"></div>

  <div class="tour-pdp-shell page-width tour-pdp-hero__content">
    <div class="tour-pdp-hero__copy">
      <p class="tour-pdp-kicker">
        {% if season_year != blank %}{{ season_year }} Season{% else %}Storm Season{% endif %}
      </p>

      <h1 class="tour-pdp-title">
        {% if hero_heading != blank %}
          {{ hero_heading | escape }}
        {% else %}
          {{ product.title | escape }}
        {% endif %}
      </h1>

      {% if hero_subtitle != blank %}
        <p class="tour-pdp-subtitle">{{ hero_subtitle | escape }}</p>
      {% endif %}

      <div class="tour-pdp-hero__cta-row">
        {% if product.selected_or_first_available_variant.available %}
          <a href="#trip-booking" class="tour-pdp-button">Reserve Your Spot</a>
        {% else %}
          <span class="tour-pdp-status tour-pdp-status--soldout">Sold Out</span>
        {% endif %}

        {% if show_scarcity %}
          <span class="tour-pdp-status">Only {{ spots_remaining }} spot{% if spots_remaining != 1 %}s{% endif %} left</span>
        {% elsif product.selected_or_first_available_variant.available %}
          <span class="tour-pdp-status">Now booking</span>
        {% endif %}
      </div>
    </div>
  </div>

  <div class="tour-pdp-facts">
    <div class="page-width">
      <div class="tour-pdp-facts__inner">
        <div class="tour-pdp-fact">
          <span class="tour-pdp-fact__label">Dates</span>
          <span class="tour-pdp-fact__value">
            {% if coming_start != blank and coming_end != blank %}
              {{ pre_start | date: '%b %-d' }} - {{ pre_end | date: '%b %-d, %Y' }}
            {% else %}
              Dates announced after booking
            {% endif %}
          </span>
        </div>
        <div class="tour-pdp-fact">
          <span class="tour-pdp-fact__label">Max Guests</span>
          <span class="tour-pdp-fact__value">{{ product.metafields.custom.max_guests | default: 6 }}</span>
        </div>
        <div class="tour-pdp-fact">
          <span class="tour-pdp-fact__label">Region</span>
          <span class="tour-pdp-fact__value">Great Plains, USA</span>
        </div>
        <div class="tour-pdp-fact">
          <span class="tour-pdp-fact__label">Activity Level</span>
          <span class="tour-pdp-fact__value">Cakewalk</span>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product Header",
  "class": "cal",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "default": "Product Header",
      "label": "t:sections.product-header.settings.title.label"
    },
  ],
  "presets": [
    {
      "name": "Product Header"
    }
  ]
}
{% endschema %}
