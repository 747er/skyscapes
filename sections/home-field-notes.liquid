<style>
  .home-field-notes {
    position: relative;
    background: #08090b;
    color: #fff;
    padding: clamp(120px, 18vh, 200px) 32px;
    overflow: hidden;
    isolation: isolate;
  }

  .home-field-notes::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      radial-gradient(60% 50% at 50% 40%, rgba(234, 185, 127, 0.08) 0%, rgba(8, 9, 11, 0) 70%),
      radial-gradient(120% 80% at 50% 100%, rgba(74, 47, 18, 0.18) 0%, rgba(8, 9, 11, 0) 70%);
  }

  .home-field-notes::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    height: 1px;
    background: linear-gradient(90deg, rgba(234, 185, 127, 0) 0%, rgba(234, 185, 127, 0.25) 50%, rgba(234, 185, 127, 0) 100%);
  }

  .home-field-notes__inner {
    max-width: 880px;
    margin: 0 auto;
    text-align: center;
    position: relative;
  }

  .home-field-notes__quotemark {
    font-family: Georgia, 'Times New Roman', serif;
    font-size: clamp(120px, 14vw, 200px);
    line-height: 0.8;
    color: rgba(234, 185, 127, 0.15);
    margin-bottom: -0.4em;
    user-select: none;
  }

  .home-field-notes__eyebrow {
    font-size: 11px;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: #eab97f;
    font-weight: 500;
    margin-bottom: 40px;
    display: inline-flex;
    align-items: center;
    gap: 14px;
  }

  .home-field-notes__eyebrow::before,
  .home-field-notes__eyebrow::after {
    content: "";
    display: inline-block;
    width: 28px;
    height: 1px;
    background: #eab97f;
    opacity: 0.5;
  }

  .home-field-notes__body {
    font-family: Georgia, 'Times New Roman', serif;
    font-style: italic;
    font-size: clamp(24px, 2.6vw, 36px);
    line-height: 1.4;
    letter-spacing: -0.005em;
    color: rgba(255, 255, 255, 0.92);
    margin: 0 0 48px;
    font-weight: 400;
    text-wrap: balance;
  }

  .home-field-notes__body em {
    font-style: italic;
    color: #eab97f;
  }

  .home-field-notes__ornament {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 22px;
    color: #eab97f;
    opacity: 0.7;
  }

  .home-field-notes__ornament span {
    display: inline-block;
    width: 36px;
    height: 1px;
    background: currentColor;
  }

  .home-field-notes__attribution {
    font-size: 11px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: rgba(234, 185, 127, 0.85);
    font-weight: 500;
  }

  @media (max-width: 749px) {
    .home-field-notes {
      padding: 96px 24px;
    }
    .home-field-notes__quotemark {
      font-size: 96px;
    }
  }
</style>

<section class="home-field-notes">
  <div class="home-field-notes__inner">
    <div class="home-field-notes__quotemark" aria-hidden="true">&ldquo;</div>

    {% if section.settings.eyebrow != blank %}
      <div class="home-field-notes__eyebrow">{{ section.settings.eyebrow }}</div>
    {% endif %}

    {% if section.settings.body != blank %}
      <p class="home-field-notes__body">{{ section.settings.body }}</p>
    {% endif %}

    <div class="home-field-notes__ornament" aria-hidden="true">
      <span></span>
      <svg width="10" height="10" viewBox="0 0 14 14" fill="currentColor">
        <path d="M7 0L8 6L14 7L8 8L7 14L6 8L0 7L6 6L7 0Z" />
      </svg>
      <span></span>
    </div>

    {% if section.settings.attribution != blank %}
      <div class="home-field-notes__attribution">{{ section.settings.attribution }}</div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Home Field Notes",
  "tag": "section",
  "class": "section-home-field-notes",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "From the Lead Forecaster"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body",
      "default": "We don\u2019t chase for the hunt. We chase for the minutes before a storm closes \u2014 when the light goes strange, the air goes electric, and a photograph becomes possible. Those minutes are why we built this."
    },
    {
      "type": "text",
      "id": "attribution",
      "label": "Attribution",
      "default": "Skyscape Photo Tours"
    }
  ],
  "presets": [
    {
      "name": "Home Field Notes"
    }
  ]
}
{% endschema %}
