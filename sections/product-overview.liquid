{% capture coming_start %}{{ product.metafields.tour_info.start_date }}{% endcapture %}
{% capture coming_end %}{{ product.metafields.tour_info.end_date }}{% endcapture %}
{% assign coming_start = coming_start | strip %}
{% assign coming_end = coming_end | strip %}
{% assign pre_start = coming_start | date: '%s' %}
{% assign pre_end = coming_end | date: '%s' %}
{% assign max_guests = product.metafields.custom.max_guests | default: 6 %}
{% assign hero_image = product.featured_image | default: section.settings.image1 %}
{% assign cinematic_image = section.settings.image5 | default: hero_image %}

{% assign spots_remaining = 0 %}
{% assign show_scarcity = false %}
{% if product.available %}
  {% for variant in product.variants %}
    {% if variant.inventory_management != blank and variant.inventory_quantity > 0 %}
      {% assign spots_remaining = spots_remaining | plus: variant.inventory_quantity %}
    {% endif %}
  {% endfor %}
  {% if spots_remaining > 0 and spots_remaining <= 6 %}
    {% assign show_scarcity = true %}
  {% endif %}
{% endif %}

{%- comment -%} Calculate duration {%- endcomment -%}
{% if coming_start != blank and coming_end != blank %}
  {% assign duration_seconds = pre_end | minus: pre_start %}
  {% assign duration_days = duration_seconds | divided_by: 86400 | plus: 1 %}
{% else %}
  {% assign duration_days = 7 %}{% endif %}

{%- comment -%} Count guides {%- endcomment -%}
{% assign guide_count = 0 %}
{% if product.metafields.custom.guides2 != blank %}
  {% assign guide_count = product.metafields.custom.guides2.value.size %}
{% endif %}

{%- comment -%} ══════════════════════════════════════
                                                   ORIENTATION
   ══════════════════════════════════════ {%- endcomment -%}

<section class="tour-pdp">

  {%- comment -%} THE FORECAST {%- endcomment -%}

  {% if product.description != blank %}
    {% assign pdp_split_title = product.title | split: ':' %}
    {% assign pdp_tour_name = pdp_split_title[0] | strip %}
    <div class="tour-pdp-forecast tour-reveal">
      <div class="tour-pdp-forecast__inner">
        <div class="tour-pdp-forecast__head">
          <div class="tour-pdp-section-label">The Forecast
            {% if pdp_tour_name != blank %}· {{ pdp_tour_name | escape }}{% endif %}
          </div>
          <h2 class="tour-pdp-forecast__title">
            The outlook for
            {% if coming_start != blank %}
              {{ pre_start | date: '%b %-d' }}{% else %}opening day{% endif %}
            to
            {% if coming_end != blank %}
              {{ pre_end | date: '%b %-d' }}{% else %}final day{% endif %}.
          </h2>
          <div class="tour-pdp-forecast__intro">Notes from the lead forecaster on the atmospheric setup for this departure.</div>
        </div>
        <div class="tour-pdp-forecast__body">
          {{ product.description }}
        </div>
      </div>
    </div>
{% endif %}

  {%- comment -%} FIELD GALLERY (slider) {%- endcomment -%}
  {%- assign slide_blocks = section.blocks | where: 'type', 'slide' -%}
  {% if slide_blocks.size > 0 %}
    <div class="tour-pdp-slider tour-reveal" data-tour-slider>
      {% if section.settings.slider_eyebrow != blank or section.settings.slider_title != blank %}
        <div class="tour-pdp-slider__header">
          {% if section.settings.slider_eyebrow != blank %}
            <div class="tour-pdp-section-label">{{ section.settings.slider_eyebrow }}</div>
          {% endif %}
          {% if section.settings.slider_title != blank %}
            <h2 class="tour-pdp-slider__title">{{ section.settings.slider_title }}</h2>
          {% endif %}
        </div>
      {% endif %}

      <div class="tour-pdp-slider__viewport">
        <div class="tour-pdp-slider__track" data-tour-slider-track>
          {% for block in slide_blocks %}
            {% if block.settings.image != blank %}
              <figure
                class="tour-pdp-slider__slide"
                data-tour-slider-slide
                {{ block.shopify_attributes }}>
                <div class="tour-pdp-slider__image-wrap">
                  <img
                    class="tour-pdp-slider__image"
                    src="{{ block.settings.image | image_url: width: 2000 }}"
                    srcset="{{ block.settings.image | image_url: width: 800 }} 800w, {{ block.settings.image | image_url: width: 1200 }} 1200w, {{ block.settings.image | image_url: width: 2000 }} 2000w"
                    sizes="(max-width: 749px) 92vw, 78vw"
                    alt="{{ block.settings.caption | default: block.settings.image.alt | escape }}"
                    loading="lazy"
                    width="{{ block.settings.image.width }}"
                    height="{{ block.settings.image.height }}">
                </div>
                {% if block.settings.caption != blank %}
                  <figcaption class="tour-pdp-slider__caption">{{ block.settings.caption }}</figcaption>
                {% endif %}
              </figure>
            {% endif %}
          {% endfor %}
        </div>
      </div>

      <div class="tour-pdp-slider__controls">
        <button
          type="button"
          class="tour-pdp-slider__btn"
          data-tour-slider-dir="prev"
          aria-label="Previous image">
          <svg
            width="20"
            height="12"
            viewBox="0 0 20 12"
            fill="none"
            aria-hidden="true">
            <path
              d="M19 6H1M1 6L6 1M1 6L6 11"
              stroke="currentColor"
              stroke-width="1.4"
              stroke-linecap="round"
              stroke-linejoin="round" />
          </svg>
        </button>
        <span class="tour-pdp-slider__counter">
          <span data-tour-slider-index>1</span>
          <span>/</span>
          <span>{{ slide_blocks.size }}</span>
        </span>
        <button
          type="button"
          class="tour-pdp-slider__btn"
          data-tour-slider-dir="next"
          aria-label="Next image">
          <svg
            width="20"
            height="12"
            viewBox="0 0 20 12"
            fill="none"
            aria-hidden="true">
            <path
              d="M1 6H19M19 6L14 1M19 6L14 11"
              stroke="currentColor"
              stroke-width="1.4"
              stroke-linecap="round"
              stroke-linejoin="round" />
          </svg>
        </button>
      </div>
    </div>
  {% endif %}


  <div class="tour-pdp-orientation tour-reveal">
    <div class="tour-pdp-orientation__left">
      <div class="tour-pdp-section-label">The Premise</div>
      <p class="tour-pdp-orientation__lede">
        A supercell will build somewhere between the Rockies and the Mississippi this spring. We will know where, when, and from which angle it photographs best. Your job is to be there. Ours is to put you in
        <em>position</em>: the right square mile of plains, at the right hour, with the right light, beside people who have spent their careers reading the sky.
      </p>

    </div>

    <div class="tour-pdp-facts-grid">
      <div class="tour-pdp-fact-row">
        <span class="tour-pdp-fact-row__num">01</span>
        <span class="tour-pdp-fact-row__label">Departure Window</span>
        <span class="tour-pdp-fact-row__value">
          {% if coming_start != blank and coming_end != blank %}
            {{ pre_start | date: '%b %-d' }} to {{ pre_end | date: '%b %-d' }}
          {% else %}
            TBA
          {% endif %}
        </span>
      </div>
      <div class="tour-pdp-fact-row">
        <span class="tour-pdp-fact-row__num">02</span>
        <span class="tour-pdp-fact-row__label">Duration</span>
        <span class="tour-pdp-fact-row__value">{{ duration_days }} days</span>
      </div>
      <div class="tour-pdp-fact-row">
        <span class="tour-pdp-fact-row__num">03</span>
        <span class="tour-pdp-fact-row__label">Group Size</span>
        <span class="tour-pdp-fact-row__value">{{ max_guests }} photographers</span>
      </div>
      {% if guide_count > 0 %}
        <div class="tour-pdp-fact-row">
          <span class="tour-pdp-fact-row__num">04</span>
          <span class="tour-pdp-fact-row__label">Guides on Trip</span>
          <span class="tour-pdp-fact-row__value">{{ guide_count }}</span>
        </div>
      {% endif %}
      <div class="tour-pdp-fact-row">
        <span class="tour-pdp-fact-row__num">
          {% if guide_count > 0 %}05{% else %}04{% endif %}
        </span>
        <span class="tour-pdp-fact-row__label">Region</span>
        <span class="tour-pdp-fact-row__value">Great Plains, USA</span>
      </div>
      {% if show_scarcity %}
        <div class="tour-pdp-fact-row">
          <span class="tour-pdp-fact-row__num">
            {% if guide_count > 0 %}06{% else %}05{% endif %}
          </span>
          <span class="tour-pdp-fact-row__label">Seats Remaining</span>
          <span class="tour-pdp-fact-row__value tour-pdp-fact-row__value--live">{{ spots_remaining }} of {{ max_guests }}</span>
        </div>
      {% endif %}
    </div>
  </div>


  {%- comment -%} ITINERARY {%- endcomment -%}

  {%- comment -%} ── Marquee ── {%- endcomment -%}
  <div class="tour-pdp-marquee">
    <div class="tour-pdp-marquee__track">
      <span>Supercells
        <span class="tour-pdp-marquee__star">✦</span>
        Mesocyclones
        <span class="tour-pdp-marquee__star">✦</span>
        Mammatus
        <span class="tour-pdp-marquee__star">✦</span>
        Wall Clouds
        <span class="tour-pdp-marquee__star">✦</span>
        Shelf Lines
        <span class="tour-pdp-marquee__star">✦</span>
        Lightning
        <span class="tour-pdp-marquee__star">✦</span>
        Plains Sunsets
        <span class="tour-pdp-marquee__star">✦</span>
      </span>
      <span>Supercells
        <span class="tour-pdp-marquee__star">✦</span>
        Mesocyclones
        <span class="tour-pdp-marquee__star">✦</span>
        Mammatus
        <span class="tour-pdp-marquee__star">✦</span>
        Wall Clouds
        <span class="tour-pdp-marquee__star">✦</span>
        Shelf Lines
        <span class="tour-pdp-marquee__star">✦</span>
        Lightning
        <span class="tour-pdp-marquee__star">✦</span>
        Plains Sunsets
        <span class="tour-pdp-marquee__star">✦</span>
      </span>
    </div>
  </div>

  <div class="tour-pdp-itinerary">
    <div class="tour-pdp-itinerary__inner">
      <div class="tour-pdp-itinerary__header tour-reveal">
        <div>
          <div class="tour-pdp-section-label">The {{ duration_days }} Days</div>
          <h2 class="tour-pdp-section-title">
            The
            <em>forecast</em>
            leads.<br>
            We adapt.<br>
            You shoot.
          </h2>
        </div>
        <p>Each morning, the forecaster reads the day's atmosphere and picks a target. Some days it's eighty miles away. Some days six hundred. The tour follows the forecast. The forecast follows the storm.</p>
      </div>

      <div class="tour-pdp-details-rows tour-reveal">
        <div class="tour-pdp-detail-row">
          <h3 class="tour-pdp-detail-row__label">Itinerary</h3>
          <p class="tour-pdp-detail-row__value">One goal every day: put you inside lens range of the most photogenic supercell on the continent. Dawn briefing, daylong repositioning, cameras ready by late afternoon. Some days we drive eighty miles. Some days six hundred. The forecast decides.</p>
        </div>

        <div class="tour-pdp-detail-row">
          <h3 class="tour-pdp-detail-row__label">What To Expect</h3>
          <p class="tour-pdp-detail-row__value">Meteorology and photography, running in parallel. Our lead forecaster tracks a cell from first cumulus to dissipation. Our photographers read the light, frame the structure, and coach you through the narrow window when the storm is most willing to be photographed.</p>
        </div>

        <div class="tour-pdp-detail-row">
          <h3 class="tour-pdp-detail-row__label">Accommodations</h3>
          <p class="tour-pdp-detail-row__value">Sometimes at dusk, sometimes well after dark, the storm releases us and we find a hotel close to tomorrow's forecast. We hold standing relationships with dozens of properties along the plains and book you a private single-occupancy room every night.</p>
        </div>

        <div class="tour-pdp-detail-row">
          <h3 class="tour-pdp-detail-row__label">Peace Of Mind</h3>
          <p class="tour-pdp-detail-row__value">Our specialty is photogenic distance. Other outfits drive into tornadoes at arm's length. We park you at the angle where a supercell renders as architecture: structured, legible, unmistakable on camera. That position is almost always the safe one, and safety is the standard we plan around.</p>
        </div>

        <div class="tour-pdp-detail-row">
          <h3 class="tour-pdp-detail-row__label">What's Included</h3>
          <p class="tour-pdp-detail-row__value">Transportation, lodging, and instruction. Every tour begins and ends in Denver, Colorado. Meals happen on the road as the storms allow; snacks and water are stocked in the vehicle throughout the day.</p>
        </div>
      </div>
    </div>
  </div>

  {%- comment -%} MID-PAGE CTA {%- endcomment -%}
  <div class="tour-pdp-mid-cta" style="background-image: url('https://cdn.shopify.com/s/files/1/0590/7863/9796/files/m4.webp?v=1776654991&width=2048');">
    <div class="tour-pdp-mid-cta__inner tour-reveal">
      <span class="tour-pdp-mid-cta__date">
        <span class="tour-pdp-mid-cta__date-rule" aria-hidden="true"></span>
        <span class="tour-pdp-mid-cta__date-text">
          {% if coming_start != blank and coming_end != blank %}
            {{ pre_start | date: '%b %-d' }} to {{ pre_end | date: '%b %-d, %Y' }}
          {% else %}
            Storm Season
          {% endif %}
        </span>
        <span class="tour-pdp-mid-cta__date-rule" aria-hidden="true"></span>
      </span>

      <h2 class="tour-pdp-mid-cta__heading">Tours for photographers who want more than luck.</h2>

      <div class="tour-pdp-mid-cta__ornament" aria-hidden="true">
        <span class="tour-pdp-mid-cta__ornament-rule"></span>
        <svg
          width="14"
          height="14"
          viewBox="0 0 14 14"
          fill="none">
          <path d="M7 0L8 6L14 7L8 8L7 14L6 8L0 7L6 6L7 0Z" fill="currentColor" />
        </svg>
        <span class="tour-pdp-mid-cta__ornament-rule"></span>
      </div>

      <p class="tour-pdp-mid-cta__copy">We handle the positioning, timing, and coaching so you can focus on making photographs when the light and weather finally align.</p>

      <ul class="tour-pdp-mid-cta__pillars">
        <li class="tour-pdp-mid-cta__pillar">
          <span class="tour-pdp-mid-cta__pillar-icon" aria-hidden="true">
            <svg
              width="30"
              height="30"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.3"
              stroke-linecap="round"
              stroke-linejoin="round">
              <circle
                cx="12"
                cy="12"
                r="9" />
              <circle
                cx="12"
                cy="12"
                r="4.5" />
              <circle
                cx="12"
                cy="12"
                r="1.2"
                fill="currentColor"
                stroke="none" />
              <path d="M12 1.5v3" />
              <path d="M12 19.5v3" />
              <path d="M1.5 12h3" />
              <path d="M19.5 12h3" />
            </svg>
          </span>
          <div class="tour-pdp-mid-cta__pillar-body">
            <span class="tour-pdp-mid-cta__pillar-title">Forecast-driven positioning</span>
            <span class="tour-pdp-mid-cta__pillar-sub">Not guesswork.</span>
          </div>
        </li>

        <li class="tour-pdp-mid-cta__pillar">
          <span class="tour-pdp-mid-cta__pillar-icon" aria-hidden="true">
            <svg
              width="30"
              height="30"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.3"
              stroke-linecap="round"
              stroke-linejoin="round">
              <path d="M17.5 16.5a5 5 0 0 0-1.3-9.83A6.5 6.5 0 0 0 4 9.5" />
              <path d="M5 16h9" />
              <path d="M12.5 13l-2.5 4.5h3l-1.5 3.5" />
            </svg>
          </span>
          <div class="tour-pdp-mid-cta__pillar-body">
            <span class="tour-pdp-mid-cta__pillar-title">Real-time adjustments</span>
            <span class="tour-pdp-mid-cta__pillar-sub">Adapt. Pivot. Capture.</span>
          </div>
        </li>

        <li class="tour-pdp-mid-cta__pillar">
          <span class="tour-pdp-mid-cta__pillar-icon" aria-hidden="true">
            <svg
              width="30"
              height="30"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.3"
              stroke-linecap="round"
              stroke-linejoin="round">
              <circle
                cx="12"
                cy="8"
                r="3.8" />
              <path d="M4.5 20.5c0-4 3.5-6.5 7.5-6.5s7.5 2.5 7.5 6.5" />
            </svg>
          </span>
          <div class="tour-pdp-mid-cta__pillar-body">
            <span class="tour-pdp-mid-cta__pillar-title">Expert coaching in the field</span>
            <span class="tour-pdp-mid-cta__pillar-sub">When it matters most.</span>
          </div>
        </li>
      </ul>

      <a
        href="#trip-booking"
        class="tour-pdp-cta-btn tour-pdp-mid-cta__btn"
        data-tour-reserve>
        <span>Reserve Your Seat</span>
        <svg
          width="18"
          height="10"
          viewBox="0 0 18 10"
          fill="none"
          aria-hidden="true">
          <path
            d="M1 5H17M17 5L13 1M17 5L13 9"
            stroke="currentColor"
            stroke-width="1.4"
            stroke-linecap="round"
            stroke-linejoin="round" />
        </svg>
      </a>
    </div>
  </div>


  {%- comment -%} GUIDES {%- endcomment -%}

  {% if product.metafields.custom.guides2 != blank %}
    <div class="tour-pdp-guides">
      <div class="tour-pdp-guides__inner">
        <div class="tour-pdp-guides__header tour-reveal">
          <div class="tour-pdp-section-label">The People</div>
          <h2 class="tour-pdp-section-title">
            {% if guide_count > 0 %}
              {{ guide_count }}
              <em>guides</em>.
            {% else %}
              Your
              <em>guides</em>.
            {% endif %}
          </h2>
          <p>Led by a forecaster. Joined by working landscape photographers. With you for every storm of the week.</p>
        </div>

        <div class="tour-pdp-guides__grid">
          {% for guide_ref in product.metafields.custom.guides2.value %}
            {% assign guide = guide_ref %}
            <div class="tour-pdp-guide tour-reveal tour-reveal--stagger" style="--reveal-i:{{ forloop.index0 }}">
              <div class="tour-pdp-guide__img">
                {% if guide.photo != blank %}
                  <img
                    src="{{ guide.photo }}"
                    alt="{{ guide.name }}"
                    loading="lazy">
                {% endif %}
              </div>
              <h3 class="tour-pdp-guide__name">{{ guide.name }}</h3>
              <div class="tour-pdp-guide__role">{{ guide.title }}</div>
              {% assign bio_text = guide.bio | strip_html | strip %}
              {% if bio_text != blank %}
                <p class="tour-pdp-guide__bio">{{ bio_text }}</p>
              {% endif %}
              {% if guide.instagram_handle or guide.five00px_handle %}
                <div class="tour-pdp-guide__socials">
                  {% if guide.instagram_handle %}
                    <a
                      href="https://instagram.com/{{ guide.instagram_handle }}"
                      target="_blank"
                      rel="noopener"
                      aria-label="Instagram">
                      <svg
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.5"><rect
                          x="2"
                          y="2"
                          width="20"
                          height="20"
                          rx="5" /><circle
                          cx="12"
                          cy="12"
                          r="5" /><circle
                          cx="17.5"
                          cy="6.5"
                          r="1"
                          fill="currentColor"
                          stroke="none" /></svg>
                    </a>
                  {% endif %}
                  {% if guide.five00px_handle %}
                    <a
                      href="https://500px.com/p/{{ guide.five00px_handle }}"
                      target="_blank"
                      rel="noopener"
                      aria-label="500px">
                      <svg viewBox="0 0 24 24" fill="currentColor"><path d="M7.5 3a4.5 4.5 0 0 0 0 9h2.25a.75.75 0 0 0 0-1.5H7.5a3 3 0 1 1 0-6h2.25a.75.75 0 0 0 0-1.5H7.5Zm9 0a.75.75 0 0 0 0 1.5A3 3 0 0 1 16.5 12a.75.75 0 0 0 0 1.5 4.5 4.5 0 0 0 0-9Z" /></svg>
                    </a>
                  {% endif %}
                </div>
              {% endif %}
            </div>
          {% endfor %}
        </div>
      </div>
    </div>
  {% endif %}

  {%- comment -%} CINEMATIC QUOTE BREAK {%- endcomment -%}
  <div class="tour-pdp-cinematic" style="background-image: url('{{ cinematic_image | image_url: width: 2400 }}');">
    <div class="tour-pdp-cinematic__quote tour-reveal">
      <blockquote>No supercell forms twice. The one you photograph will be the only one of its kind that ever exists.</blockquote>
    </div>
</div>

  {%- comment -%} GALLERY — ASYMMETRIC GRID {%- endcomment -%}
  {% assign gallery_images = product.images %}
  {% if gallery_images.size > 0 %}
    <div class="tour-pdp-gallery">
      <div class="tour-pdp-gallery__header tour-reveal">
        <div>
          <div class="tour-pdp-section-label">Field Work</div>
          <h2 class="tour-pdp-section-title">From
            <em>seasons</em><br>past.</h2>
        </div>
        <p>Photographs from past expeditions and the guides who lead them.</p>
      </div>

      <div class="tour-pdp-gallery__grid tour-reveal">
        {% for image in gallery_images limit: 6 %}
          {% assign grid_class = 'tour-pdp-g' | append: forloop.index %}
          <div class="tour-pdp-g-item {{ grid_class }}" data-caption="{{ image.alt | default: product.title }}">
            {{ image | image_url: width: 1600 | image_tag: loading: 'lazy', alt: image.alt | default: product.title }}
          </div>
      {% endfor %}

        {%- comment -%} Fill remaining slots from section settings if product has fewer than 6 images {%- endcomment -%}
        {% assign filled = gallery_images.size %}
        {% if filled < 6 %}
          {% assign remaining = 6 | minus: filled %}
          {% assign section_images = '' | split: '' %}

          {% if section.settings.image1 != blank %}
            {% assign section_images = section_images | concat: section.settings.image1 %}
          {% endif %}
          {% if section.settings.image2 != blank %}
            {% assign section_images = section_images | concat: section.settings.image2 %}
          {% endif %}
          {% if section.settings.image3 != blank %}
            {% assign section_images = section_images | concat: section.settings.image3 %}
          {% endif %}
          {% if section.settings.image4 != blank %}
            {% assign section_images = section_images | concat: section.settings.image4 %}
          {% endif %}
          {% if section.settings.image5 != blank %}
            {% assign section_images = section_images | concat: section.settings.image5 %}
          {% endif %}
          {% if section.settings.image6 != blank %}
            {% assign section_images = section_images | concat: section.settings.image6 %}
          {% endif %}

          {% for i in (1..remaining) %}
            {% assign idx = filled | plus: i %}
            {% assign grid_class = 'tour-pdp-g' | append: idx %}
            {% assign setting_key = 'image' | append: i %}
            {% assign fill_img = section.settings[setting_key] %}
            {% if fill_img != blank %}
              <div class="tour-pdp-g-item {{ grid_class }}" data-caption="{{ product.title }}">
                {{ fill_img | image_url: width: 1600 | image_tag: loading: 'lazy', alt: product.title }}
              </div>
            {% endif %}
          {% endfor %}
        {% endif %}
      </div>
    </div>
  {% endif %}

</section>

<script>
  (function() {
  /* ── Scroll Reveal ── */
  var reveals = document.querySelectorAll('.tour-reveal');
  if (!reveals.length) return;

  var viewH = window.innerHeight;
  reveals.forEach(function(el) {
    if (el.getBoundingClientRect().top < viewH + 80) {
      el.classList.add('tour-revealed');
    }
  });

  var observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        entry.target.classList.add('tour-revealed');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.08, rootMargin: '0px 0px -30px 0px' });

  reveals.forEach(function(el) {
    if (!el.classList.contains('tour-revealed')) {
      observer.observe(el);
    }
  });
  })();

  /* ── Reserve CTAs → submit the product form (add to cart) ── */
  (function() {
    document.addEventListener('click', function(e) {
      var btn = e.target.closest('[data-tour-reserve]');
      if (!btn) return;

      var form = document.querySelector('product-form form')
        || document.querySelector('form[action$="/cart/add"]');
      if (!form) return; /* let the anchor fall through to #trip-booking */

      e.preventDefault();

      if (typeof form.requestSubmit === 'function') {
        form.requestSubmit();
      } else {
        form.dispatchEvent(new Event('submit', { cancelable: true, bubbles: true }));
      }
    });
  })();

  /* ── Field Gallery slider ── */
  (function() {
    var sliders = document.querySelectorAll('[data-tour-slider]');
    sliders.forEach(function(root) {
      var track = root.querySelector('[data-tour-slider-track]');
      var slides = root.querySelectorAll('[data-tour-slider-slide]');
      var indexEl = root.querySelector('[data-tour-slider-index]');
      var btns = root.querySelectorAll('[data-tour-slider-dir]');
      if (!track || !slides.length) return;

      function currentIndex() {
        var scroll = track.scrollLeft;
        var nearest = 0;
        var nearestDist = Infinity;
        slides.forEach(function(s, i) {
          var dist = Math.abs(s.offsetLeft - scroll);
          if (dist < nearestDist) {
            nearestDist = dist;
            nearest = i;
          }
        });
        return nearest;
      }

      function updateCounter() {
        if (indexEl) indexEl.textContent = currentIndex() + 1;
      }

      function goTo(i) {
        i = Math.max(0, Math.min(slides.length - 1, i));
        var target = slides[i];
        if (!target) return;
        track.scrollTo({ left: target.offsetLeft, behavior: 'smooth' });
      }

      btns.forEach(function(btn) {
        btn.addEventListener('click', function() {
          var dir = btn.getAttribute('data-tour-slider-dir');
          var i = currentIndex();
          goTo(dir === 'next' ? i + 1 : i - 1);
        });
      });

      var raf;
      track.addEventListener('scroll', function() {
        if (raf) cancelAnimationFrame(raf);
        raf = requestAnimationFrame(updateCounter);
      }, { passive: true });

      updateCounter();
    });
  })();
</script>

