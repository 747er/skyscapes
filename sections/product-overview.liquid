{% capture coming_start %}{{ product.metafields.tour_info.start_date }}{% endcapture %}
{% capture coming_end %}{{ product.metafields.tour_info.end_date }}{% endcapture %}
{% assign coming_start = coming_start | strip %}
{% assign coming_end = coming_end | strip %}
{% assign pre_start = coming_start | date: '%s' %}
{% assign pre_end = coming_end | date: '%s' %}
{% assign hero_image = product.featured_image | default: section.settings.image1 %}
{% assign overview_main = section.settings.image1 | default: hero_image %}
{% assign overview_side_top = section.settings.image2 | default: section.settings.image5 %}
{% assign overview_side_bottom = section.settings.image3 | default: section.settings.image6 %}
{% assign map_image = section.settings.image4 | default: hero_image %}
{% assign mid_cta_image = section.settings.image5 | default: hero_image %}
{% assign fullbleed_image = section.settings.image6 | default: hero_image %}

<section class="tour-pdp tour-pdp-section">

  {%- comment -%} ── Overview ── {%- endcomment -%}
  <div class="tour-pdp-shell page-width">
    <div class="tour-pdp-overview__grid tour-reveal">
      <div class="tour-pdp-overview__body">
        <p class="tour-pdp-kicker">Expedition Overview</p>
        <h2 class="tour-pdp-heading">Chase possibility.<br>Capture history.</h2>

        <div class="tour-pdp-feature-list">
          <div class="tour-pdp-feature tour-reveal tour-reveal--stagger" style="--reveal-i:0">Led by a veteran storm forecaster</div>
          <div class="tour-pdp-feature tour-reveal tour-reveal--stagger" style="--reveal-i:1">Small group expedition pacing</div>
          <div class="tour-pdp-feature tour-reveal tour-reveal--stagger" style="--reveal-i:2">Field coaching from world-class photographers</div>
          <div class="tour-pdp-feature tour-reveal tour-reveal--stagger" style="--reveal-i:3">Long-horizon days built around real storm structure</div>
        </div>
      </div>

      <div class="tour-pdp-collage">
        <div class="tour-pdp-collage__main">
          {% if overview_main != blank %}
            {{ overview_main | image_url: width: 1600 | image_tag: loading: 'lazy', alt: product.title }}
          {% endif %}
        </div>
        <div class="tour-pdp-collage__stack">
          <div class="tour-pdp-collage__stack-item">
            {% if overview_side_top != blank %}
              {{ overview_side_top | image_url: width: 900 | image_tag: loading: 'lazy', alt: product.title }}
            {% endif %}
          </div>
          <div class="tour-pdp-collage__stack-item">
            {% if overview_side_bottom != blank %}
              {{ overview_side_bottom | image_url: width: 900 | image_tag: loading: 'lazy', alt: product.title }}
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  </div>

  {%- comment -%} ── Horizontal Scrolling Gallery ── {%- endcomment -%}
  {% if product.images.size > 1 %}
    <div class="tour-pdp-gallery tour-reveal">
      <div class="tour-pdp-gallery__track">
        {% for image in product.images %}
          <div class="tour-pdp-gallery__item">
            {{ image | image_url: width: 900 | image_tag: loading: 'lazy', alt: product.title }}
          </div>
        {% endfor %}
        {%- comment -%} Fill with section images if product images are sparse {%- endcomment -%}
        {% if product.images.size < 5 %}
          {% if section.settings.image1 != blank %}
            <div class="tour-pdp-gallery__item">
              {{ section.settings.image1 | image_url: width: 900 | image_tag: loading: 'lazy', alt: product.title }}
            </div>
          {% endif %}
          {% if section.settings.image2 != blank %}
            <div class="tour-pdp-gallery__item">
              {{ section.settings.image2 | image_url: width: 900 | image_tag: loading: 'lazy', alt: product.title }}
            </div>
          {% endif %}
          {% if section.settings.image3 != blank %}
            <div class="tour-pdp-gallery__item">
              {{ section.settings.image3 | image_url: width: 900 | image_tag: loading: 'lazy', alt: product.title }}
            </div>
          {% endif %}
        {% endif %}
      </div>
    </div>
  {% endif %}

  {%- comment -%} ── Stats Divider ── {%- endcomment -%}
  <div class="tour-pdp-divider tour-reveal">
    <div class="tour-pdp-divider__glow"></div>
    <div class="tour-pdp-shell page-width">
      <div class="tour-pdp-stat-strip">
        <div class="tour-pdp-stat">
          <span class="tour-pdp-stat__number">{{ product.metafields.custom.max_guests | default: 6 }}</span>
          <span class="tour-pdp-stat__label">Max Guests</span>
        </div>
        <div class="tour-pdp-stat">
          <span class="tour-pdp-stat__number">
            {%- if coming_start != blank and coming_end != blank -%}
              {%- assign duration_seconds = pre_end | minus: pre_start -%}
              {%- assign duration_days = duration_seconds | divided_by: 86400 | plus: 1 -%}
              {{ duration_days }}
            {%- else -%}
              7
            {%- endif -%}
          </span>
          <span class="tour-pdp-stat__label">Days</span>
        </div>
        <div class="tour-pdp-stat">
          <span class="tour-pdp-stat__number">2k+</span>
          <span class="tour-pdp-stat__label">Miles Covered</span>
        </div>
        <div class="tour-pdp-stat">
          <span class="tour-pdp-stat__number">15+</span>
          <span class="tour-pdp-stat__label">Years Experience</span>
        </div>
      </div>
    </div>
  </div>

  {%- comment -%} ── Itinerary (expandable days) ── {%- endcomment -%}
  <div class="tour-pdp-shell page-width">
    <div class="tour-pdp-itinerary tour-reveal">
      <div class="tour-pdp-itinerary__header">
        <p class="tour-pdp-kicker">Day By Day</p>
        <h2 class="tour-pdp-heading">Itinerary</h2>
      </div>

      <div class="tour-pdp-itinerary__days">
        <details class="tour-pdp-day" open>
          <summary class="tour-pdp-day__summary">
            <span class="tour-pdp-day__number">01</span>
            <div class="tour-pdp-day__meta">
              <span class="tour-pdp-day__date">
                {% if coming_start != blank %}{{ pre_start | date: '%b %-d' }}{% else %}Day 1{% endif %}
              </span>
              <h3 class="tour-pdp-day__title">Arrival & Briefing</h3>
            </div>
            <span class="tour-pdp-day__icon" aria-hidden="true"></span>
          </summary>
          <div class="tour-pdp-day__body">
            <div class="tour-pdp-day__content">
              <p>Meet in Denver, review the forecast setup, check gear, and align on the chase approach before we head out across the plains.</p>
            </div>
            {% if map_image != blank %}
              <div class="tour-pdp-day__image">
                {{ map_image | image_url: width: 800 | image_tag: loading: 'lazy', alt: 'Arrival briefing' }}
              </div>
            {% endif %}
          </div>
        </details>

        <details class="tour-pdp-day">
          <summary class="tour-pdp-day__summary">
            <span class="tour-pdp-day__number">02</span>
            <div class="tour-pdp-day__meta">
              <span class="tour-pdp-day__date">
                {% if coming_start != blank and coming_end != blank %}
                  {{ pre_start | date: '%b %-d' }} &ndash; {{ pre_end | date: '%b %-d' }}
                {% else %}
                  Core chase window
                {% endif %}
              </span>
              <h3 class="tour-pdp-day__title">The Chase</h3>
            </div>
            <span class="tour-pdp-day__icon" aria-hidden="true"></span>
          </summary>
          <div class="tour-pdp-day__body">
            <div class="tour-pdp-day__content">
              <p>Every day starts with a weather discussion, then we reposition in real time for the best light, structure, and safe storm access we can find.</p>
            </div>
            {% if overview_side_top != blank %}
              <div class="tour-pdp-day__image">
                {{ overview_side_top | image_url: width: 800 | image_tag: loading: 'lazy', alt: 'Storm chasing' }}
              </div>
            {% endif %}
          </div>
        </details>

        <details class="tour-pdp-day">
          <summary class="tour-pdp-day__summary">
            <span class="tour-pdp-day__number">03</span>
            <div class="tour-pdp-day__meta">
              <span class="tour-pdp-day__date">
                {% if coming_end != blank %}{{ pre_end | date: '%b %-d' }}{% else %}Final day{% endif %}
              </span>
              <h3 class="tour-pdp-day__title">Wrap & Depart</h3>
            </div>
            <span class="tour-pdp-day__icon" aria-hidden="true"></span>
          </summary>
          <div class="tour-pdp-day__body">
            <div class="tour-pdp-day__content">
              <p>We close out in Denver with a final review, departures, and a memory card full of storm structure, lightning, and atmosphere.</p>
            </div>
          </div>
        </details>
      </div>
    </div>
  </div>

  {%- comment -%} ── Full-Bleed Image Break ── {%- endcomment -%}
  <div class="tour-pdp-fullbleed tour-reveal">
    <div class="tour-pdp-fullbleed__media" style="background-image: url('{{ fullbleed_image | image_url: width: 2400 }}');"></div>
    <div class="tour-pdp-fullbleed__vignette"></div>
    <div class="tour-pdp-fullbleed__caption page-width">
      <p class="tour-pdp-kicker">
        {% if coming_start != blank and coming_end != blank %}
          {{ pre_start | date: '%b %-d' }} &ndash; {{ pre_end | date: '%b %-d, %Y' }}
        {% else %}
          Storm Season
        {% endif %}
      </p>
      <h2 class="tour-pdp-fullbleed__heading">Ready To Chase?</h2>
      <a href="#trip-booking" class="tour-pdp-button">Reserve Your Spot</a>
    </div>
  </div>

  {%- comment -%} ── Guides ── {%- endcomment -%}
  <div class="tour-pdp-shell page-width">
    <div class="tour-pdp-guides tour-reveal">
      <p class="tour-pdp-kicker">Meet Your Guides</p>
      <h2 class="tour-pdp-heading">Your Guides</h2>

      {% if product.metafields.custom.guides2 != blank %}
        <div class="tour-pdp-guides__grid">
          {% for guide_ref in product.metafields.custom.guides2.value %}
            {% assign guide = guide_ref %}
            <div class="tour-reveal tour-reveal--stagger" style="--reveal-i:{{ forloop.index0 }}">
              {% render 'guide', guide: guide, abbreviated: true %}
            </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>
</section>

{%- comment -%} ── Details + Description (Light Section) ── {%- endcomment -%}
<section class="tour-pdp-light">
  <div class="tour-pdp-shell page-width">
    <div class="tour-pdp-light__inner">
      <p class="tour-pdp-kicker tour-pdp-kicker--dark">The Details</p>

      <div class="tour-pdp-details__grid tour-pdp-details__grid--light tour-reveal">
        <article class="tour-pdp-detail-card tour-pdp-detail-card--light tour-reveal tour-reveal--stagger" style="--reveal-i:0">
          <h3 class="tour-pdp-detail-card__title">Chase Approach</h3>
          <p class="tour-pdp-detail-card__copy">
            Our forecaster tracks the setup and positions the group for structure, light, and a measured, safety-first interception strategy.
          </p>
        </article>

        <article class="tour-pdp-detail-card tour-pdp-detail-card--light tour-reveal tour-reveal--stagger" style="--reveal-i:1">
          <h3 class="tour-pdp-detail-card__title">Accommodations</h3>
          <p class="tour-pdp-detail-card__copy">
            We move with the weather, then settle into reliable hotels close to the route so you can rest well and be ready for the next day.
          </p>
        </article>

        <article class="tour-pdp-detail-card tour-pdp-detail-card--light tour-reveal tour-reveal--stagger" style="--reveal-i:2">
          <h3 class="tour-pdp-detail-card__title">Peace Of Mind</h3>
          <p class="tour-pdp-detail-card__copy">
            Safety comes first. We aim for photogenic structure and dramatic atmosphere, not unnecessary proximity to tornado-producing storms.
          </p>
        </article>

        <article class="tour-pdp-detail-card tour-pdp-detail-card--light tour-reveal tour-reveal--stagger" style="--reveal-i:3">
          <h3 class="tour-pdp-detail-card__title">What's Included</h3>
          <p class="tour-pdp-detail-card__copy">
            Transportation, lodging, daily field education, and in-the-moment photographic guidance are included throughout the tour.
          </p>
        </article>
      </div>

      {% if product.description != blank %}
        <div class="tour-pdp-light__description tour-reveal">
          <div class="tour-pdp-rte tour-pdp-rte--dark">
            {{ product.description }}
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</section>

<script>
(function() {
  /* ── Scroll Reveal ── */
  var reveals = document.querySelectorAll('.tour-reveal');
  if (!reveals.length) return;

  var viewH = window.innerHeight;
  reveals.forEach(function(el) {
    if (el.getBoundingClientRect().top < viewH + 80) {
      el.classList.add('tour-revealed');
    }
  });

  var observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        entry.target.classList.add('tour-revealed');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.08, rootMargin: '0px 0px -30px 0px' });

  reveals.forEach(function(el) {
    if (!el.classList.contains('tour-revealed')) {
      observer.observe(el);
    }
  });

  /* ── Gallery Drag Scroll ── */
  var gallery = document.querySelector('.tour-pdp-gallery__track');
  if (gallery) {
    var isDown = false, startX, scrollLeft;
    gallery.addEventListener('mousedown', function(e) {
      isDown = true;
      gallery.classList.add('tour-pdp-gallery--grabbing');
      startX = e.pageX - gallery.offsetLeft;
      scrollLeft = gallery.scrollLeft;
    });
    gallery.addEventListener('mouseleave', function() {
      isDown = false;
      gallery.classList.remove('tour-pdp-gallery--grabbing');
    });
    gallery.addEventListener('mouseup', function() {
      isDown = false;
      gallery.classList.remove('tour-pdp-gallery--grabbing');
    });
    gallery.addEventListener('mousemove', function(e) {
      if (!isDown) return;
      e.preventDefault();
      var x = e.pageX - gallery.offsetLeft;
      gallery.scrollLeft = scrollLeft - (x - startX) * 1.5;
    });
  }
})();
</script>

{% schema %}
{
  "name": "Product Overview",
  "class": "cal",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image1",
      "label": "image 1"
    },
    {
      "type": "image_picker",
      "id": "image2",
      "label": "image 2"
    },
    {
      "type": "image_picker",
      "id": "image3",
      "label": "image 3"
    },
    {
      "type": "image_picker",
      "id": "image4",
      "label": "image 4"
    },
    {
      "type": "image_picker",
      "id": "image5",
