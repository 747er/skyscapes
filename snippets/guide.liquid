{%- assign guide_name = guide.name -%}
{%- assign instagram_handle = guide.instagram_handle -%}
{%- assign five00px_handle = guide.five00px_handle -%}
{%- assign guide_title = guide.title -%}
{%- assign guide_pic = guide.photo -%}
{%- assign bio = guide.bio -%}
{%- assign abbreviated_bio = bio | strip_html -%}

{% if abbreviated %}
  <article class="tour-guide-card">
    <div class="tour-guide-card__media {{ guide.slug }}" style="background-image: url('{{ guide_pic }}');"></div>

    <div class="tour-guide-card__content">
      <span class="tour-guide-card__eyebrow">{{ guide_title }}</span>
      <h3 class="tour-guide-card__name">{{ guide_name }}</h3>
      <p class="tour-guide-card__bio">{{ abbreviated_bio }}</p>

      {% if instagram_handle or five00px_handle %}
        <div class="tour-guide-card__socials">
          {% if instagram_handle %}
            {% render 'guide-instagram', instagram_handle: instagram_handle %}
          {% endif %}
          {% if five00px_handle %}
            {% render 'guide-500', five00px_handle: five00px_handle %}
          {% endif %}
        </div>
      {% endif %}
    </div>
  </article>
{% else %}
  <div class="guide-container {% if abbreviated %}abbreviated{% endif %}">
    <div class="guide-pic {{guide.slug}}" style="background-image: url('{{ guide_pic }}'); background-size: cover; background-repeat: no-repeat;"></div>

    <div class="guide-content">
      <div class="guide-socials">
        {% if instagram_handle %}
          {% render 'guide-instagram'
            , instagram_handle: instagram_handle %}
        {% endif %}
        {% if five00px_handle %}
          {% render 'guide-500'
            , five00px_handle: five00px_handle %}
        {% endif %}
      </div>

      <div class="guide-banner">
        <div class="guide-heading">{{ guide_title }}</div>
        <h1 class="guide-header">{{ guide_name }}</h1>
      </div>

      <p class="guide-bio">{{ bio }}</p>
    </div>
  </div>
{% endif %}
